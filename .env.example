# التشغيل المحلي
ARCHIVE_HOST=127.0.0.1
ARCHIVE_PORT=8787
DATABASE_URL=sqlite:///./data/archive.db
ARCHIVE_DATA_DIR=./data
LOG_LEVEL=INFO
# 0 = بدون حد من داخل البرنامج
MAX_UPLOAD_MB=0

# OCR: local | openai | google | azure | aws
OCR_PROVIDER=local
OCR_LANGUAGES=ara+eng
TESSERACT_CMD=
TESSDATA_DIR=./tessdata

# OpenAI Vision (اختياري)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Google Document AI (اختياري)
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_PROJECT_ID=
GOOGLE_LOCATION=us
GOOGLE_PROCESSOR_ID=

# Azure Document Intelligence (اختياري)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# AWS Textract (اختياري)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1

# للواجهات المنفصلة مستقبلًا. النسخة الحالية تخدم الواجهة من نفس السيرفر.
FRONTEND_API_URL=http://127.0.0.1:8787
